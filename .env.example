# MongoDB Configuration
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DB=kelulusan
MONGODB_COLLECTION=students

# DNS Fallback (Optional, comma separated)
# Digunakan jika ISP memblokir resolver SRV MongoDB Atlas
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# Public Default Config (Optional)
NEXT_PUBLIC_ANNOUNCEMENT_MEMO=Informasi selanjutnya akan diumumkan melalui wali kelas masing-masing.
